{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "env": {
    "DEEPSEEK_API_KEY": {
      "description": "DeepSeek API Key",
      "required": true,
      "value": ""
    },
    "WECHAT_CORP_ID": {
      "description": "企业微信CorpID",
      "value": "ww47ae0142fcfd5800"
    },
    "WECHAT_TOKEN": {
      "description": "企业微信Token",
      "value": "Sj5eiUTyKeE5e"
    },
    "WECHAT_ENCODING_AES_KEY": {
      "description": "企业微信EncodingAESKey",
      "value": "kE5sXAI1f74kjbpfpl0PytYNMYcnOW9Blik9lYDBtcX"
    },
    "WECHAT_AGENT_ID": {
      "description": "企业微信AgentID",
      "value": "1000004"
    }
  }
}
